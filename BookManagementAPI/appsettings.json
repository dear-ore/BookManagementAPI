{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "ConnectionStrings": {
    "DefaultConnection": "Server=Your_server_name;Database=Your_Db_Name;Trusted_Connection=True;"
  },

  "Jwt": {
    "Key": "Your_Super_Secret_Key_Here(DO_NOT_SHARE!)",
    "Issuer": "Your_API_Name/Localhost",
    "Audience": "Your_API_Users"
  }, 

  "AllowedHosts": "*"
}
